FROM maven:3.9-eclipse-temurin-21-alpine

ENV GLASSFISH_HOME=/opt/glassfish7
ENV PATH="${GLASSFISH_HOME}/bin:${PATH}"

RUN apk add --no-cache bash curl unzip \
    && curl -fsSL -o /tmp/glassfish.zip \
       https://download.eclipse.org/ee4j/glassfish/glassfish-7.0.22.zip \
    && unzip -q /tmp/glassfish.zip -d /opt \
    && curl -L https://jdbc.postgresql.org/download/postgresql-42.7.10.jar \
       -o ${GLASSFISH_HOME}/glassfish/lib/postgresql.jar \
    && rm /tmp/glassfish.zip

WORKDIR /workspace

CMD ["bash", "./scripts/glassfish-docker-dev.sh"]
